{
  "permissions": {
    "allow": [
      "Bash(curl -s https://api.github.com/repos/denoland/deno/releases/latest)",
      "Bash(curl -fL -o deno.zip https://github.com/denoland/deno/releases/download/v2.9.1/deno-aarch64-apple-darwin.zip)",
      "Bash(curl -fsL -o deno.zip.sha256sum https://github.com/denoland/deno/releases/download/v2.9.1/deno-aarch64-apple-darwin.zip.sha256sum)",
      "Bash(shasum -a 256 -c deno.zip.sha256sum)",
      "Bash(shasum -a 256 deno.zip)",
      "Bash(unzip -o deno.zip)",
      "Bash(rm deno.zip deno.zip.sha256sum)",
      "Bash(chmod +x deno)",
      "Bash(./deno --version)",
      "WebFetch(domain:docs.deno.com)",
      "Bash(code . *)",
      "Skill(run)",
      "Bash(deno --version)",
      "WebFetch(domain:docs.claude.com)",
      "Bash(git --version)",
      "Bash(./tools/deno run *)"
    ]
  }
}
